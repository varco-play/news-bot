# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM (required)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 2. Your personal chat ID — use /start in the bot to see it, or message @userinfobot
#    This chat gets digests automatically and you become the admin.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 3. (Optional) Extra admin user IDs — comma separated, can change bot settings
#    Get user IDs from /start (shows "Your user ID")
#    Example: TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_ADMIN_IDS=


# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI (optional — enables AI summarization, importance scoring, /ask Q&A)
# Free tier: 15 requests/minute (no credit card needed, no expiration)
# Get your free API key at https://aistudio.google.com/apikey
# Without this key the bot uses heuristic scoring (still fully functional)
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here


# ─────────────────────────────────────────────────────────────────────────────
# NEWS API (free tier: 100 req/day)
# Sign up at https://newsapi.org/register
# ─────────────────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ─────────────────────────────────────────────────────────────────────────────
# REDDIT (free)
# Create app at https://www.reddit.com/prefs/apps
# Choose "script" type, redirect URI must be: http://localhost
# ─────────────────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=NewsBot/1.0


# ─────────────────────────────────────────────────────────────────────────────
# TWITTER / X API (optional)
# Sign up at https://developer.twitter.com
# Free tier gives read-only access
# ─────────────────────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here


# ─────────────────────────────────────────────────────────────────────────────
# INSTAGRAM via APIFY (optional)
# HOW TO GET YOUR FREE APIFY TOKEN:
#   1. Go to https://apify.com → Sign Up Free (no credit card needed)
#   2. Log in → click your avatar → Settings → Integrations
#   3. Under "Personal API tokens" → Create token → name it "NewsBot"
#   4. Copy the token and paste it below
#   5. In Telegram, run: /togglesource instagram  (to enable)
#   6. Add accounts: /addinstagram openai
# Free tier: $5/month compute credits (~1,000+ scrapes)
# ─────────────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=your_apify_api_token_here


# ─────────────────────────────────────────────────────────────────────────────
# DIGEST TIME (24h format, UTC)
# ─────────────────────────────────────────────────────────────────────────────
DAILY_DIGEST_HOUR=8
DAILY_DIGEST_MINUTE=0
